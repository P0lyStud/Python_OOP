"""Класс-список"""
class MagicList:
    def __init__(self, list = []): # по умолчанию пустой список
        self.list = list
        pass

    """магический метод показывает значение элемента списка по ключу"""
    def __getitem__(self, key):
        return self.list[key]
        pass

    """магический метод устанавливает значенчие элемента списка по ключу"""
    def __setitem__(self, key, value):
        # if self.list[key] == None:
        #     self.append[key]
        self.list[key] = value
        pass

    """магический метод выводит длину списка"""
    def __len__(self):
        return len(self.list)
        pass

    """метод добавляет элемент в конец списка"""
    def append(self, item):
        return self.list.append(item)
        pass


try:
    ml = MagicList()
    ml.append(1); ml.append(2); ml.append(3)
    print(ml[0])        # 1
    ml[1] = 99
    print(ml[1:3])      # [99, 3]
    print(len(ml))      # 3
except Exception as e:
    print(e)